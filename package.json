{
    "version": "0.0.0",
    "name": "loyalty-app",
    "scripts": {
        "preview": "vite preview",
        "build": "npm run build:member",
        "build:member": "tsc -b && cross-env VITE_APP_MODE=member vite build",
        "build:staff": "tsc -b && cross-env VITE_APP_MODE=staff vite build",
        "dev": "vite",
        "dev:member": "vite",
        "dev:staff": "cross-env VITE_APP_MODE=staff vite",
        "lint": "eslint .",
        "verify:supabase": "node scripts/verify-supabase.mjs",
        "setup:staff-n19": "node scripts/setup-staff-n19.mjs"
    },
    "devDependencies": {
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.20",
        "cross-env": "^10.1.0",
        "postcss": "^8.4.41",
        "tailwindcss": "^3.4.10",
        "typescript": "^5.5.3",
        "vite": "^5.4.1",
        "vite-plugin-pwa": "^1.3.0"
    },
    "type": "module",
    "dependencies": {
        "@supabase/supabase-js": "^2.45.0",
        "@types/qrcode.react": "^1.0.5",
        "@types/react-qr-reader": "^2.1.7",
        "html5-qrcode": "^2.3.8",
        "lucide-react": "^0.559.0",
        "qrcode.react": "^4.2.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-qr-reader": "^3.0.0-beta-1",
        "react-router-dom": "^6.26.0"
    },
    "private": true
